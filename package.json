{
  "name": "agent-char-workspace",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "concurrently -n server,web -c yellow,cyan \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "pnpm --filter @agent-char/server dev",
    "dev:web": "pnpm --filter @agent-char/web dev",
    "build": "pnpm --filter @agent-char/server build && pnpm --filter @agent-char/web build",
    "start": "pnpm --filter @agent-char/server start",
    "preview:web": "pnpm --filter @agent-char/web preview"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
